async fn connect(
    State(state): State<Arc<AppState>>,
    Json(req): Json<ConnectRequest>,
) -> Result<Json<ConnectResponse>, (StatusCode, Json<serde_json::Value>)> {

    let user = state.users
        .find_one(doc! { "login": &req.login, "deleted": false }, None)
        .await
        .map_err(|_| (StatusCode::INTERNAL_SERVER_ERROR, Json(serde_json::json!({"error": "Database error"}))))?;

    let user = match user {
        Some(u) => u,
        None => {
            return Err((StatusCode::UNAUTHORIZED, Json(serde_json::json!({"error": "Invalid login or password"}))));
        }
    };

    if !verify_password(&req.password, &user.password_hash) {
        return Err((StatusCode::UNAUTHORIZED, Json(serde_json::json!({"error": "Invalid login or password"}))));
    }

    let workstation = state.workstations
        .find_one(doc! { "allowed_users": &req.login }, None)
        .await
        .map_err(|_| (StatusCode::INTERNAL_SERVER_ERROR, Json(serde_json::json!({"error": "Database error"}))))?;

    let workstation = match workstation {
        Some(w) => w,
        None => {
            return Err((StatusCode::BAD_REQUEST, Json(serde_json::json!({"error": "No workstation assigned. Contact administrator."}))));
        }
    };

    let mut cursor = state.connections
        .find(doc! { "user_login": &req.login, "deleted": false }, None)
        .await
        .map_err(|_| (StatusCode::INTERNAL_SERVER_ERROR, Json(serde_json::json!({"error": "Database error"}))))?;

    while let Ok(Some(conn)) = cursor.try_next().await {
        let _ = state.mikrotik.remove_ip_from_rdp_list(&conn.user_external_ip).await;

        let _ = state.connections
            .update_one(
                doc! { "_id": conn.id.unwrap() },
                doc! { "$set": { "deleted": true, "deleted_at": Utc::now().timestamp_millis() } },
                None
            )
            .await;
    }

    println!("[TEST] Would add IP {} to router RDP list", req.external_ip);

    let connection = Connection {
        id: None,
        user_login: req.login.clone(),
        user_external_ip: req.external_ip.clone(),
        workstation_id: workstation.id.unwrap(),
        created_at: Utc::now().timestamp_millis(),
        deleted: false,
        deleted_at: None,
    };

    state.connections
        .insert_one(connection, None)
        .await
        .map_err(|_| (StatusCode::INTERNAL_SERVER_ERROR, Json(serde_json::json!({"error": "Failed to save connection"}))))?;

    let rdp_string = format!("{}:{}", ROUTER_EXTERNAL_IP, workstation.router_port);

    Ok(Json(ConnectResponse { rdp_string }))
}

