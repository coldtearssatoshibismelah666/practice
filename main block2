#[tokio::main]
async fn main() {
    let mongo_client = MongoClient::with_uri_str("mongodb://localhost:27017")
        .await
        .expect("Failed to connect to MongoDB");

    let db = mongo_client.database("322");

    let users_collection: Collection<User> = db.collection("users");
    let _ = users_collection.create_index(mongodb::IndexModel::builder()
                                              .keys(doc! { "login": 1 })
                                              .options(mongodb::options::IndexOptions::builder().unique(true).build())
                                              .build(), None).await;

    let state = Arc::new(AppState::new(&db).await);

    let app = Router::new()
        .route("/time", get(get_time))
        .route("/users", post(create_user))
        .route("/users/:login", put(update_user))
        .route("/users/:login", delete(delete_user))
        .route("/workstations", post(create_workstation))
        .route("/workstations/:id", put(update_workstation))
        .route("/workstations/:id", delete(delete_workstation))
        .route("/connect", post(connect))
        .with_state(state);

    let listener = tokio::net::TcpListener::bind("0.0.0.0:5000")
        .await
        .unwrap();

    println!("Server running on http://localhost:5000");
    println!("");
    println!("ENDPOINTS:");
    println!("  GET    /time");
    println!("  POST   /users");
    println!("  PUT    /users/:login");
    println!("  DELETE /users/:login");
    println!("  POST   /workstations");
    println!("  PUT    /workstations/:id");
    println!("  DELETE /workstations/:id");
    println!("  POST   /connect");

    axum::serve(listener, app)
        .await
        .unwrap();
}
