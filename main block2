//HANDLERS

async fn get_time() -> String {
    time::OffsetDateTime::now_utc().to_string()
}

async fn create_user(
    State(state): State<Arc<AppState>>,
    Json(req): Json<CreateUserRequest>,
) -> StatusCode {
    let now = Utc::now().timestamp_millis();

    let user = User {
        id: None,
        last_name: req.last_name,
        first_name: req.first_name,
        login: req.login,
        password_hash: hash_password(&req.password),
        created_at: now,
        created_by: req.created_by.clone(),
        updated_at: now,
        updated_by: req.created_by,
        deleted: false,
    };

    match state.users.insert_one(user, None).await {
        Ok(_) => StatusCode::CREATED,
        Err(_) => StatusCode::INTERNAL_SERVER_ERROR,
    }
}

async fn update_user(
    State(state): State<Arc<AppState>>,
    axum::extract::Path(login): axum::extract::Path<String>,
    Json(req): Json<UpdateUserRequest>,
) -> StatusCode {
    let mut update_doc = doc! {};
    let now = Utc::now().timestamp_millis();

    if let Some(last_name) = req.last_name {
        update_doc.insert("last_name", last_name);
    }
    if let Some(first_name) = req.first_name {
        update_doc.insert("first_name", first_name);
    }
    if let Some(password) = req.password {
        update_doc.insert("password_hash", hash_password(&password));
    }
    update_doc.insert("updated_at", now);
    update_doc.insert("updated_by", req.updated_by);

    let result = state.users
        .update_one(doc! { "login": &login, "deleted": false }, doc! { "$set": update_doc }, None)
        .await;

    match result {
        Ok(updated) if updated.modified_count > 0 => StatusCode::OK,
        Ok(_) => StatusCode::NOT_FOUND,
        Err(_) => StatusCode::INTERNAL_SERVER_ERROR,
    }
}

async fn delete_user(
    State(state): State<Arc<AppState>>,
    axum::extract::Path(login): axum::extract::Path<String>,
) -> StatusCode {
    let mut cursor = match state.connections
        .find(doc! { "user_login": &login, "deleted": false }, None)
        .await {
        Ok(c) => c,
        Err(_) => return StatusCode::INTERNAL_SERVER_ERROR,
    };

    while let Ok(Some(conn)) = cursor.try_next().await {
        let _ = state.mikrotik.remove_ip_from_rdp_list(&conn.user_external_ip).await;

        let _ = state.connections
            .update_one(
                doc! { "_id": conn.id.unwrap() },
                doc! { "$set": { "deleted": true, "deleted_at": Utc::now().timestamp_millis() } },
                None
            )
            .await;
    }

    let result = state.users
        .update_one(
            doc! { "login": &login, "deleted": false },
            doc! { "$set": { "deleted": true, "updated_at": Utc::now().timestamp_millis() } },
            None
        )
        .await;

    match result {
        Ok(updated) if updated.modified_count > 0 => StatusCode::OK,
        Ok(_) => StatusCode::NOT_FOUND,
        Err(_) => StatusCode::INTERNAL_SERVER_ERROR,
    }
}

