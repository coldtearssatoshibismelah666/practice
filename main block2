//AUTH

fn hash_password(password: &str) -> String {
    let mut hasher = Sha256::new();
    hasher.update(password.as_bytes());
    format!("{:x}", hasher.finalize())
}

fn verify_password(password: &str, hash: &str) -> bool {
    hash_password(password) == hash
}

//MIKROTIK CLIENT

const ROUTER_IP: &str = "188.242.27.197";
const ROUTER_USER: &str = "test";
const ROUTER_PASS: &str = "MsRus4215";
const ROUTER_EXTERNAL_IP: &str = "188.242.27.197";

struct MikroTikClient {
    client: HttpClient,
    auth_header: String,
    base_url: String,
}

impl MikroTikClient {
    fn new() -> Self {
        let auth = format!("{}:{}", ROUTER_USER, ROUTER_PASS);
        let auth_header = format!("Basic {}", BASE64_STANDARD.encode(&auth));

        let client = HttpClient::builder()
            .danger_accept_invalid_certs(true)
            .build()
            .unwrap();

        Self {
            client,
            auth_header,
            base_url: format!("http://{}/rest", ROUTER_IP),
        }
    }

    async fn add_ip_to_rdp_list(&self, ip: &str) -> Result<(), String> {
        let url = format!("{}/ip/firewall/address-list", self.base_url);

        let body = serde_json::json!({
            "address": ip,
            "list": "rdp",
            "timeout": "1d"
        });

        let response = self.client
            .put(&url)
            .header("Authorization", &self.auth_header)
            .header("Content-Type", "application/json")
            .json(&body)
            .send()
            .await
            .map_err(|e| format!("HTTP error: {}", e))?;

        if response.status().is_success() {
            return Ok(());
        }

        Err(format!("MikroTik error: {}", response.text().await.unwrap_or_default()))
    }

    async fn remove_ip_from_rdp_list(&self, ip: &str) -> Result<(), String> {
        let find_url = format!("{}/ip/firewall/address-list?list=rdp", self.base_url);

        let response = self.client
            .get(&find_url)
            .header("Authorization", &self.auth_header)
            .send()
            .await
            .map_err(|e| format!("HTTP error: {}", e))?;

        if response.status().is_success() {
            let data: Vec<serde_json::Value> = response.json().await.unwrap_or_default();
            for entry in data {
                if let Some(addr) = entry.get("address").and_then(|v| v.as_str()) {
                    if addr == ip {
                        if let Some(id) = entry.get(".id").and_then(|v| v.as_str()) {
                            let delete_url = format!("{}/ip/firewall/address-list/{}", self.base_url, id);
                            let _ = self.client
                                .delete(&delete_url)
                                .header("Authorization", &self.auth_header)
                                .send()
                                .await;
                        }
                    }
                }
            }
        }

        Ok(())
    }
}

