[package]
name = "rdp_manager"
version = "0.1.0"
edition = "2021"

[dependencies]
axum = "0.7"
tokio = { version = "1", features = ["full"] }
mongodb = "2.8"
serde = { version = "1", features = ["derive"] }
serde_json = "1"
time = "0.3"
chrono = "0.4"
sha2 = "0.10"
base64 = "0.22"
reqwest = { version = "0.12", features = ["json"] }
futures-util = "0.3"
